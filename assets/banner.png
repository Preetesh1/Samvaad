<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 240" width="800" height="240">
  <!-- White background -->
  <rect width="800" height="240" fill="#FFFFFF" rx="16"/>

  <!-- Subtle warm bg tint -->
  <rect width="800" height="240" fill="#FDF8F3" rx="16"/>

  <!-- Decorative right circle -->
  <circle cx="720" cy="120" r="180" fill="#FFF3E8" opacity="0.6"/>
  <circle cx="750" cy="90" r="80" fill="#FFE8D0" opacity="0.4"/>

  <!-- Back bubble (ink dark) -->
  <rect x="88" y="66" width="72" height="54" rx="14" fill="#1F1A14"/>
  <polygon points="98,120 88,140 114,120" fill="#1F1A14"/>

  <!-- Front bubble (saffron) -->
  <rect x="60" y="44" width="72" height="54" rx="14" fill="#D4621A"/>
  <polygon points="116,98 130,118 108,98" fill="#D4621A"/>

  <!-- Dots inside front bubble -->
  <circle cx="80" cy="71" r="5.5" fill="#FFFFFF"/>
  <circle cx="96" cy="71" r="5.5" fill="#FFFFFF"/>
  <circle cx="112" cy="71" r="5.5" fill="#FFFFFF"/>

  <!-- Wordmark Sam -->
  <text x="158" y="106"
    font-family="Georgia, 'Times New Roman', serif"
    font-size="64"
    font-weight="bold"
    fill="#1F1A14"
    letter-spacing="-2">Sam</text>

  <!-- Wordmark vaad -->
  <text x="310" y="106"
    font-family="Georgia, 'Times New Roman', serif"
    font-size="64"
    font-weight="bold"
    fill="#D4621A"
    letter-spacing="-2">vaad</text>

  <!-- Accent underline -->
  <line x1="310" y1="114" x2="540" y2="114" stroke="#D4621A" stroke-width="3.5" stroke-linecap="round"/>

  <!-- Hindi tagline -->
  <text x="158" y="144"
    font-family="Arial, sans-serif"
    font-size="15"
    fill="#C4A882"
    letter-spacing="2.5">संवाद  ·  CONVERSATIONS THAT CONNECT</text>

  <!-- Version badge -->
  <rect x="158" y="158" width="82" height="22" rx="11" fill="#D4621A" opacity="0.1"/>
  <rect x="158" y="158" width="82" height="22" rx="11" fill="none" stroke="#D4621A" stroke-width="1" opacity="0.3"/>
  <text x="199" y="174"
    font-family="Arial, sans-serif"
    font-size="10"
    font-weight="bold"
    fill="#D4621A"
    text-anchor="middle"
    letter-spacing="1">v1.0.0</text>

  <!-- Tech stack pills -->
  <rect x="252" y="158" width="72" height="22" rx="11" fill="#1F1A14" opacity="0.06"/>
  <text x="288" y="174" font-family="Arial, sans-serif" font-size="10" font-weight="bold" fill="#1F1A14" text-anchor="middle" opacity="0.5" letter-spacing="0.5">Next.js</text>

  <rect x="334" y="158" width="82" height="22" rx="11" fill="#1F1A14" opacity="0.06"/>
  <text x="375" y="174" font-family="Arial, sans-serif" font-size="10" font-weight="bold" fill="#1F1A14" text-anchor="middle" opacity="0.5" letter-spacing="0.5">Socket.io</text>

  <rect x="426" y="158" width="72" height="22" rx="11" fill="#1F1A14" opacity="0.06"/>
  <text x="462" y="174" font-family="Arial, sans-serif" font-size="10" font-weight="bold" fill="#1F1A14" text-anchor="middle" opacity="0.5" letter-spacing="0.5">WebRTC</text>

  <rect x="508" y="158" width="80" height="22" rx="11" fill="#1F1A14" opacity="0.06"/>
  <text x="548" y="174" font-family="Arial, sans-serif" font-size="10" font-weight="bold" fill="#1F1A14" text-anchor="middle" opacity="0.5" letter-spacing="0.5">MongoDB</text>
</svg>
